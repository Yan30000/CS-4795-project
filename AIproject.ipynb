import heapq
import time
import random
import copy
from typing import List, Tuple, Dict, Optional, Callable
import matplotlib.pyplot as plt
import matplotlib.patches as patches

# ============================================
# Puzzle Class
# ============================================

class Puzzle:
    def __init__(self, grid: List[List[int]]):
        self.grid = grid
        self.n = len(grid)
        self.blank_pos = self._find_blank()

    def _find_blank(self) -> Tuple[int, int]:
        for i in range(self.n):
            for j in range(self.n):
                if self.grid[i][j] == 0:
                    return (i, j)
        raise ValueError("Blank not found")

    def get_blank_pos(self) -> Tuple[int, int]:
        return self.blank_pos

    def get_grid(self) -> List[List[int]]:
        return [row[:] for row in self.grid]

    def get_flat(self) -> Tuple[int, ...]:
        return tuple(tile for row in self.grid for tile in row)

    def get_neighbors(self) -> List['Puzzle']:
        neighbors = []
        i, j = self.blank_pos
        moves = [(-1, 0), (1, 0), (0, -1), (0, 1)]
        for di, dj in moves:
            ni, nj = i + di, j + dj
            if 0 <= ni < self.n and 0 <= nj < self.n:
                new_grid = [row[:] for row in self.grid]
                new_grid[i][j], new_grid[ni][nj] = new_grid[ni][nj], new_grid[i][j]
                neighbors.append(Puzzle(new_grid))
        return neighbors

    def __eq__(self, other):
        return self.get_flat() == other.get_flat()

    def __hash__(self):
        return hash(self.get_flat())

    def __str__(self):
        result = []
        for row in self.grid:
            result.append(' '.join(str(tile) if tile != 0 else '_' for tile in row))
        return '\n'.join(result)


def create_goal_puzzle(n: int) -> Puzzle:
    grid = [[i * n + j + 1 for j in range(n)] for i in range(n)]
    grid[n-1][n-1] = 0
    return Puzzle(grid)


def create_random_puzzle(n: int, moves: int = 100) -> Puzzle:
    puzzle = create_goal_puzzle(n)
    for _ in range(moves):
        neighbors = puzzle.get_neighbors()
        puzzle = random.choice(neighbors)
    return puzzle


def is_solvable(puzzle: Puzzle) -> bool:
    flat = [tile for row in puzzle.grid for tile in row if tile != 0]
    inv_count = 0
    for i in range(len(flat)):
        for j in range(i + 1, len(flat)):
            if flat[i] > flat[j]:
                inv_count += 1
    if puzzle.n % 2 == 1:
        return inv_count % 2 == 0
    else:
        blank_row_from_bottom = puzzle.n - puzzle.blank_pos[0]
        if blank_row_from_bottom % 2 == 0:
            return inv_count % 2 == 1
        else:
            return inv_count % 2 == 0


# ============================================
# Heuristics
# ============================================

def misplaced_tiles(puzzle: Puzzle, goal: Puzzle) -> int:
    count = 0
    goal_grid = goal.get_grid()
    for i in range(puzzle.n):
        for j in range(puzzle.n):
            if puzzle.grid[i][j] != 0 and puzzle.grid[i][j] != goal_grid[i][j]:
                count += 1
    return count


def manhattan_distance(puzzle: Puzzle, goal: Puzzle) -> int:
    goal_positions = {}
    goal_grid = goal.get_grid()
    for i in range(puzzle.n):
        for j in range(puzzle.n):
            goal_positions[goal_grid[i][j]] = (i, j)
    distance = 0
    for i in range(puzzle.n):
        for j in range(puzzle.n):
            tile = puzzle.grid[i][j]
            if tile != 0:
                gi, gj = goal_positions[tile]
                distance += abs(i - gi) + abs(j - gj)
    return distance


def custom_heuristic(puzzle: Puzzle, goal: Puzzle) -> float:
    base = manhattan_distance(puzzle, goal)
    bi, bj = puzzle.get_blank_pos()
    goal_bi, goal_bj = goal.get_blank_pos()
    return base + 0.01 * (abs(bi - goal_bi) + abs(bj - goal_bj))


def inadmissible_heuristic(puzzle: Puzzle, goal: Puzzle) -> int:
    base = manhattan_distance(puzzle, goal)
    penalty = 0
    goal_grid = goal.get_grid()
    for i in range(puzzle.n):
        for j in range(puzzle.n):
            tile = puzzle.grid[i][j]
            if tile != 0:
                for gi in range(puzzle.n):
                    for gj in range(puzzle.n):
                        if goal_grid[gi][gj] == tile:
                            if abs(i - gi) > 0 and abs(j - gj) > 0:
                                penalty += 2
                            break
    return base + penalty


def get_heuristic(name: str):
    return {
        'misplaced': misplaced_tiles,
        'manhattan': manhattan_distance,
        'custom': custom_heuristic,
        'inadmissible': inadmissible_heuristic
    }.get(name, manhattan_distance)


# ============================================
# A* Algorithm
# ============================================

class AStarResult:
    def __init__(self):
        self.solution_path = []
        self.explored_states = 0
        self.time_ms = 0.0
        self.max_frontier_size = 0
        self.solution_length = 0
        self.success = False
        self.heuristic_name = ""

    def __str__(self):
        return (f"Heuristic: {self.heuristic_name}\n"
                f"Success: {self.success}\n"
                f"Solution length: {self.solution_length}\n"
                f"Explored states: {self.explored_states}\n"
                f"Max frontier size: {self.max_frontier_size}\n"
                f"Time: {self.time_ms:.2f} ms")


def a_star(start: Puzzle, goal: Puzzle, heuristic_func, heuristic_name: str = "unknown", timeout_seconds: float = 60.0) -> AStarResult:
    result = AStarResult()
    result.heuristic_name = heuristic_name
    start_time = time.time()

    counter = 0
    open_set = []
    g_score = {start.get_flat(): 0}
    f_score = {start.get_flat(): heuristic_func(start, goal)}
    came_from = {}

    heapq.heappush(open_set, (f_score[start.get_flat()], counter, start))

    while open_set:
        if time.time() - start_time > timeout_seconds:
            result.success = False
            result.time_ms = (time.time() - start_time) * 1000
            return result

        result.max_frontier_size = max(result.max_frontier_size, len(open_set))
        _, _, current = heapq.heappop(open_set)

        if current.get_flat() == goal.get_flat():
            path = []
            while current.get_flat() in came_from:
                path.append(current)
                current = came_from[current.get_flat()]
            path.append(start)
            path.reverse()
            result.solution_path = path
            result.solution_length = len(path) - 1
            result.success = True
            result.explored_states = len(g_score)
            result.time_ms = (time.time() - start_time) * 1000
            return result

        for neighbor in current.get_neighbors():
            tentative_g = g_score[current.get_flat()] + 1
            if (neighbor.get_flat() not in g_score or tentative_g < g_score[neighbor.get_flat()]):
                came_from[neighbor.get_flat()] = current
                g_score[neighbor.get_flat()] = tentative_g
                f = tentative_g + heuristic_func(neighbor, goal)
                f_score[neighbor.get_flat()] = f
                counter += 1
                heapq.heappush(open_set, (f, counter, neighbor))

    result.success = False
    result.time_ms = (time.time() - start_time) * 1000
    result.explored_states = len(g_score)
    return result


# ============================================
# Visualization
# ============================================

def draw_puzzle(puzzle: Puzzle, ax=None, title: str = ""):
    if ax is None:
        fig, ax = plt.subplots(figsize=(4, 4))
    n = puzzle.n
    grid = puzzle.get_grid()
    for i in range(n + 1):
        ax.axhline(i, color='black', linewidth=2)
        ax.axvline(i, color='black', linewidth=2)
    for i in range(n):
        for j in range(n):
            tile = grid[i][j]
            if tile != 0:
                rect = patches.Rectangle((j, n - 1 - i), 1, 1, facecolor='lightblue', edgecolor='black')
                ax.add_patch(rect)
                ax.text(j + 0.5, n - 0.5 - i, str(tile), ha='center', va='center', fontsize=20, fontweight='bold')
            else:
                rect = patches.Rectangle((j, n - 1 - i), 1, 1, facecolor='lightgray', edgecolor='black')
                ax.add_patch(rect)
    ax.set_xlim(0, n)
    ax.set_ylim(0, n)
    ax.set_aspect('equal')
    ax.axis('off')
    ax.set_title(title, fontsize=12)
    return ax


def visualize_solution_path(path: List[Puzzle], max_states: int = 8):
    if not path:
        print("No solution path")
        return
    if len(path) > max_states:
        step = len(path) // max_states
        display_path = path[::step]
        if path[-1] not in display_path:
            display_path.append(path[-1])
    else:
        display_path = path
    n = len(display_path)
    cols = min(4, n)
    rows = (n + cols - 1) // cols
    fig, axes = plt.subplots(rows, cols, figsize=(cols * 3, rows * 3))
    if rows == 1 and cols == 1:
        axes = [axes]
    else:
        axes = axes.flatten()
    for i, puzzle in enumerate(display_path):
        draw_puzzle(puzzle, axes[i], title=f"Step {i}")
    for i in range(len(display_path), len(axes)):
        axes[i].axis('off')
    plt.suptitle("Solution Path", fontsize=16)
    plt.tight_layout()
    plt.show()


def plot_performance_comparison(results: List[dict]):
    heuristics = ['misplaced', 'manhattan', 'custom']
    data = {}
    for h in heuristics:
        h_results = [r for r in results if r['heuristic'] == h and r['success']]
        if h_results:
            data[h] = [r['explored_states'] for r in h_results]
    if not data:
        print("No data to plot")
        return
    fig, axes = plt.subplots(1, 2, figsize=(12, 5))
    avg_states = [sum(data[h]) / len(data[h]) for h in heuristics if h in data]
    heuristics_plot = [h for h in heuristics if h in data]
    axes[0].bar(heuristics_plot, avg_states, color=['#FF6B6B', '#4ECDC4', '#45B7D1'][:len(heuristics_plot)])
    axes[0].set_ylabel('Average Explored States')
    axes[0].set_title('Explored States (log scale)')
    axes[0].set_yscale('log')
    for i, v in enumerate(avg_states):
        axes[0].text(i, v, f'{v:.0f}', ha='center', va='bottom')
    avg_time = [sum(data[h]) / len(data[h]) for h in heuristics if h in data]
    axes[1].bar(heuristics_plot, avg_time, color=['#FF6B6B', '#4ECDC4', '#45B7D1'][:len(heuristics_plot)])
    axes[1].set_ylabel('Average Time (ms)')
    axes[1].set_title('Computation Time')
    for i, v in enumerate(avg_time):
        axes[1].text(i, v, f'{v:.1f}ms', ha='center', va='bottom')
    plt.tight_layout()
    plt.show()


# ============================================
# Experiments
# ============================================

def run_single_experiment(puzzle: Puzzle, goal: Puzzle, heuristic_name: str, timeout_seconds: float = 60.0) -> Dict:
    result = a_star(puzzle, goal, get_heuristic(heuristic_name), heuristic_name, timeout_seconds=timeout_seconds)
    return {
        'heuristic': heuristic_name,
        'success': result.success,
        'solution_length': result.solution_length,
        'explored_states': result.explored_states,
        'max_frontier': result.max_frontier_size,
        'time_ms': result.time_ms
    }


def run_experiments(puzzle_sizes=[3], instances=10, moves=50, heuristics=['misplaced', 'manhattan', 'custom'], timeout_seconds: float = 30.0):
    all_results = []
    for n in puzzle_sizes:
        print(f"\n{'='*50}")
        print(f"Experiments for {n}x{n} puzzle")
        print(f"{'='*50}")
        goal = create_goal_puzzle(n)
        for inst in range(instances):
            while True:
                puzzle = create_random_puzzle(n, moves)
                if is_solvable(puzzle):
                    break
            print(f"\nInstance {inst+1}/{instances}")
            for h in heuristics:
                print(f"  {h}...", end=" ", flush=True)
                r = run_single_experiment(puzzle, goal, h, timeout_seconds=timeout_seconds)
                r['n'] = n
                r['instance_id'] = inst
                all_results.append(r)
                if r['success']:
                    print(f"OK (states: {r['explored_states']}, time: {r['time_ms']:.0f}ms)")
                else:
                    print("FAILED")
    return all_results


def print_summary(results):
    print("\n" + "="*60)
    print("SUMMARY")
    print("="*60)
    for h in ['misplaced', 'manhattan', 'custom']:
        hr = [r for r in results if r['heuristic'] == h and r['success']]
        if hr:
            avg_exp = sum(r['explored_states'] for r in hr) / len(hr)
            avg_t = sum(r['time_ms'] for r in hr) / len(hr)
            print(f"\n{h.upper()}:")
            print(f"  Avg explored: {avg_exp:.0f}")
            print(f"  Avg time: {avg_t:.1f} ms")


def run_failure_demo():
    print("\n" + "="*60)
    print("FAILURE DEMONSTRATION: Inadmissible Heuristic")
    print("="*60)
    goal = create_goal_puzzle(3)
    puzzle = create_random_puzzle(3, 20)
    while not is_solvable(puzzle):
        puzzle = create_random_puzzle(3, 20)
    print(f"\nPuzzle:\n{puzzle}")

    print("\n--- ADMISSIBLE (Manhattan) ---")
    r1 = a_star(puzzle, goal, manhattan_distance, 'manhattan')
    if r1.success:
        print(f"  Length: {r1.solution_length}, States: {r1.explored_states}")

    print("\n--- INADMISSIBLE ---")
    r2 = a_star(puzzle, goal, inadmissible_heuristic, 'inadmissible')
    if r2.success:
        print(f"  Length: {r2.solution_length}, States: {r2.explored_states}")

    if r1.success and r2.success and r2.solution_length > r1.solution_length:
        print("\n INADMISSIBLE heuristic produced NON-OPTIMAL solution!")


